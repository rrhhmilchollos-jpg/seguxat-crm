# --- Base de datos ---
# Cadena de conexión a la base de datos de Seguxat (MongoDB Atlas / Railway).
# Sustituye esto por la cadena real de Seguxat. NUNCA subas el .env real a git.
MONGODB_URI=mongodb+srv://usuario:password@cluster.seguxat.mongodb.net/seguxat-crm

# --- Sesiones ---
# Genera uno nuevo y aleatorio, por ejemplo con: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- Verificación en dos pasos con Google ---
# Client ID de OAuth2 creado en https://console.cloud.google.com/apis/credentials
# (Tipo: ID de cliente de OAuth -> Aplicación web)
GOOGLE_CLIENT_ID=560128973845-o2otvdgfboc3igncs9rovd506bt64l5e.apps.googleusercontent.com

# --- Cuenta de director inicial (solo para el script de seed) ---
# Estos valores se usan UNA VEZ al ejecutar `npm run seed:director`.
# No los dejes en este archivo si vas a compartir el repositorio.
DIRECTOR_NAME="Ivan"
DIRECTOR_EMAIL=director@seguxat.es
DIRECTOR_PASSWORD=cambia-esta-contrasena

# --- Servidor ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- Stripe (cobros de presupuestos/facturas a clientes) ---
# Clave secreta de tu cuenta de Stripe: Dashboard > Developers > API keys.
# Sin esta clave, el presupuesto se envía igualmente por correo pero SIN botón de pago.
STRIPE_SECRET_KEY=sk_live_o_sk_test_tu_clave_secreta_de_stripe

# --- Resend (envío de correos: bienvenida, alertas ARIA, presupuestos) ---
RESEND_API_KEY=tu_api_key_de_resend
# Remitente verificado en Resend. Mientras no verifiques un dominio propio,
# usa el remitente de pruebas por defecto: Seguxat CRM <onboarding@resend.dev>
RESEND_FROM_EMAIL=Seguxat <facturacion@seguxat.es>
